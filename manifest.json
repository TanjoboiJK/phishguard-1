{
  "manifest_version": 3,
  "name": "PhishGuard : Email Safety Checker",
  "version": "3.1",
  "description": "Detects phishing emails in Gmail using Groq AI",
  "permissions": ["storage"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://api.groq.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }

  
}
